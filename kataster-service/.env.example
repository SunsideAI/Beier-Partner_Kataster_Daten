# Copy to .env for local development. Never commit .env itself.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000

# ── GET /kataster Auth (X-API-Key Header) ───────────────────────────────────
# Kommasepariert für mehrere Keys (Multi-Tenant). Leer = Auth deaktiviert (lokal).
# Auf Railway MUSS dieser Wert gesetzt sein — sonst crasht der Container.
API_KEYS=change-me-secret-key

# ── POST /pipedrive/webhook Auth (HTTP Basic Auth) ───────────────────────────
# Pipedrive-Webhook-URL: https://USER:PASSWORD@dein-service.railway.app/pipedrive/webhook
# Auf Railway MUSS beides gesetzt sein — sonst crasht der Container.
PIPEDRIVE_WEBHOOK_USER=kataster
PIPEDRIVE_WEBHOOK_PASSWORD=change-me-webhook-password

# Optional: HMAC-SHA256 Signatur-Verifikation (zweite Verteidigungslinie)
# In Pipedrive-Webhook-Einstellungen als "Shared Secret" hinterlegen.
# Wenn leer: nur Warn-Log, kein Block.
PIPEDRIVE_WEBHOOK_SECRET=

# ── Pipedrive API (Rückschreiben der Katasterdaten) ──────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=yourcompany

# Pipedrive custom field key des Adressfelds im Deal
# Zu finden unter: Pipedrive → Einstellungen → Datenfelder → Deals → API-Schlüssel
PIPEDRIVE_ADDRESS_FIELD_KEY=abc123fieldkey

# Pipedrive custom field key des Gemarkung-Felds (für Idempotenz-Check)
# Wenn gesetzt: Webhook überspringt Deals, bei denen Adresse unverändert UND Gemarkung bereits gefüllt
PIPEDRIVE_GEMARKUNG_FIELD_KEY=

# JSON-Map: Kataster-Feldname → Pipedrive custom field key
# Kataster-Felder: gemarkung, gemarkungsnummer, flur, flurstueck, flurstueckskennzeichen,
#                  amtliche_flaeche_qm, lagebezeichnung, gemeinde, nutzungsart, bundesland
PIPEDRIVE_FIELD_MAP={"gemarkung":"key1","flur":"key2","flurstueck":"key3","amtliche_flaeche_qm":"key4","lagebezeichnung":"key5","bundesland":"key6"}
